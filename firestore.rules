rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasCommandId(data) {
      return data.keys().hasAny(['commandId']) &&
        data.commandId is string &&
        data.commandId.size() > 0;
    }

    function hasOrganizationId(data) {
      return data.keys().hasAny(['organizationId']) &&
        data.organizationId is string &&
        data.organizationId.size() > 0;
    }

    function organizationIdFromData(data) {
      return hasOrganizationId(data) ? data.organizationId : data.commandId;
    }

    function hasValidOrganizationReference(data) {
      return (hasOrganizationId(data) || hasCommandId(data)) &&
        (!hasOrganizationId(data) ||
          !hasCommandId(data) ||
          data.organizationId == data.commandId);
    }

    function isActiveMembershipData(data) {
      return (
          (data.keys().hasAny(['status']) && data.status == 'active') ||
          (data.keys().hasAny(['isActive']) && data.isActive == true)
        ) &&
        (!data.keys().hasAny(['status']) || data.status == 'active') &&
        (!data.keys().hasAny(['isActive']) || data.isActive == true);
    }

    function isValidMembershipRole(role) {
      return role == 'member' ||
        role == 'boardMember' ||
        role == 'admin';
    }

    function commandExistsAfter(commandId) {
      return existsAfter(/databases/$(database)/documents/commands/$(commandId)) &&
        getAfter(/databases/$(database)/documents/commands/$(commandId)).data.createdBy is string;
    }

    function isCommandCreator(commandId) {
      return commandExistsAfter(commandId) &&
        getAfter(/databases/$(database)/documents/commands/$(commandId)).data.createdBy ==
          request.auth.uid;
    }

    function activeMembershipId(commandId) {
      return request.auth.uid + '_' + commandId;
    }

    function membershipIdForUser(userId, commandId) {
      return userId + '_' + commandId;
    }

    function isActiveMember(commandId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))) &&
        isActiveMembershipData(
          get(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))).data
        );
    }

    function isActiveMemberOf(userId, commandId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memberships/$(membershipIdForUser(userId, commandId))) &&
        isActiveMembershipData(
          get(/databases/$(database)/documents/memberships/$(membershipIdForUser(userId, commandId))).data
        );
    }

    function isActiveAdmin(commandId) {
      return isActiveMember(commandId) &&
        get(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))).data.role == 'admin';
    }

    function isOwnMembershipCreate() {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        isActiveMembershipData(request.resource.data);
    }

    function isOwnAdminMembershipForCreatedCommand() {
      return isOwnMembershipCreate() &&
        request.resource.data.role == 'admin' &&
        isCommandCreator(organizationIdFromData(request.resource.data));
    }

    function isOwnMemberMembership() {
      return isOwnMembershipCreate() &&
        request.resource.data.role == 'member' &&
        commandExistsAfter(organizationIdFromData(request.resource.data));
    }

    function keepsMembershipIdentityAndRole() {
      return request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        request.resource.data.role == resource.data.role;
    }

    function isAdminMembershipRoleUpdate() {
      return request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidMembershipRole(request.resource.data.role) &&
        isActiveAdmin(organizationIdFromData(resource.data));
    }

    function isValidAvailabilityStatus(status) {
      return status == 'offDuty' ||
        status == 'onDuty' ||
        status == 'delayed';
    }

    function hasValidDelayedResponse(data) {
      return data.status != 'delayed' ||
        (
          data.keys().hasAny(['responseMinutes']) &&
          data.responseMinutes is int &&
          data.responseMinutes > 0
        );
    }

    function hasValidAvailabilityResponse(data) {
      return !data.keys().hasAny(['responseMinutes']) ||
        data.responseMinutes == null ||
        data.responseMinutes is int;
    }

    function isOwnAvailabilityWrite(availabilityId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        availabilityId == request.auth.uid + '_' + organizationIdFromData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data)) &&
        isValidAvailabilityStatus(request.resource.data.status) &&
        hasValidAvailabilityResponse(request.resource.data) &&
        hasValidDelayedResponse(request.resource.data);
    }

    function isValidReminderInterval(intervalHours) {
      return intervalHours == 12 ||
        intervalHours == 24 ||
        intervalHours == 48 ||
        intervalHours == 168;
    }

    function isValidReminderTime(reminderTime) {
      return reminderTime is string &&
        reminderTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isValidReminderSettingsData(data) {
      return data.keys().hasAll(['enabled', 'intervalHours', 'reminderTime']) &&
        data.enabled is bool &&
        isValidReminderInterval(data.intervalHours) &&
        isValidReminderTime(data.reminderTime);
    }

    function isOwnReminderSettingsWrite(settingId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == settingId &&
        hasValidOrganizationReference(request.resource.data) &&
        settingId == request.auth.uid + '_' + organizationIdFromData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data)) &&
        isValidReminderSettingsData(request.resource.data);
    }

    function isValidEquipmentCategory(category) {
      return category == 'vessel' ||
        category == 'engine' ||
        category == 'rescue' ||
        category == 'medical' ||
        category == 'radio' ||
        category == 'safety' ||
        category == 'other';
    }

    function isValidEquipmentStatus(status) {
      return status == 'ok' ||
        status == 'needsMaintenance' ||
        status == 'broken' ||
        status == 'outOfService';
    }

    function isValidEquipmentData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'name',
          'category',
          'status',
          'location',
          'note',
          'createdBy'
        ]) &&
        data.id is string &&
        data.name is string &&
        data.name.size() > 0 &&
        data.location is string &&
        (
          !data.keys().hasAny(['nextMaintenanceDate']) ||
          data.nextMaintenanceDate is string
        ) &&
        data.note is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidEquipmentCategory(data.category) &&
        isValidEquipmentStatus(data.status);
    }

    function isEquipmentCreate(equipmentId) {
      return signedIn() &&
        request.resource.data.id == equipmentId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidEquipmentData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(request.resource.data));
    }

    function isEquipmentUpdate(equipmentId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == equipmentId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidEquipmentData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(resource.data));
    }

    function isValidOperationLogType(type) {
      return type == 'departure' ||
        type == 'arrivalOnScene' ||
        type == 'searchStarted' ||
        type == 'searchEnded' ||
        type == 'patientRecovered' ||
        type == 'towingStarted' ||
        type == 'towingEnded' ||
        type == 'returnedToBase' ||
        type == 'note' ||
        type == 'other';
    }

    function isValidOperationLogStatus(status) {
      return status == 'created' ||
        status == 'departed' ||
        status == 'arrived' ||
        status == 'inProgress' ||
        status == 'completed' ||
        status == 'returnedToBase';
    }

    function isValidOperationLogData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'createdBy',
          'createdByName',
          'type',
          'title',
          'description'
        ]) &&
        data.id is string &&
        data.createdBy is string &&
        data.createdByName is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        (
          !data.keys().hasAny(['status']) ||
          isValidOperationLogStatus(data.status)
        ) &&
        (
          !data.keys().hasAny(['calloutId']) ||
          (
            data.calloutId is string &&
            data.calloutId.size() > 0 &&
            existsAfter(
              /databases/$(database)/documents/callouts/$(data.calloutId)
            ) &&
            organizationIdFromData(
              getAfter(
                /databases/$(database)/documents/callouts/$(data.calloutId)
              ).data
            ) == organizationIdFromData(data)
          )
        ) &&
        hasValidOrganizationReference(data) &&
        isValidOperationLogType(data.type);
    }

    function isOperationLogCreate(logId) {
      return signedIn() &&
        request.resource.data.id == logId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidOperationLogData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data));
    }

    function isOperationLogStatusUpdate(logId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == logId &&
        request.resource.data.status is string &&
        isValidOperationLogStatus(request.resource.data.status) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]) &&
        isActiveMember(organizationIdFromData(resource.data));
    }

    function isValidActivityType(type) {
      return type == 'training' ||
        type == 'meeting' ||
        type == 'maintenance' ||
        type == 'exercise' ||
        type == 'event' ||
        type == 'other';
    }

    function isValidActivityData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'title',
          'description',
          'type',
          'startTime',
          'endTime',
          'location',
          'createdBy'
        ]) &&
        data.id is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        data.startTime is string &&
        data.endTime is string &&
        data.location is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidActivityType(data.type);
    }

    function isActivityCreate(activityId) {
      return signedIn() &&
        request.resource.data.id == activityId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidActivityData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(request.resource.data));
    }

    function isActivityUpdate(activityId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == activityId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidActivityData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(resource.data));
    }

    function isValidParticipationStatus(status) {
      return status == 'attending' ||
        status == 'notAttending' ||
        status == 'maybe';
    }

    function activityExists(activityId) {
      return exists(/databases/$(database)/documents/activities/$(activityId));
    }

    function activityOrganizationMatches(activityId, data) {
      return activityExists(activityId) &&
        organizationIdFromData(
          get(/databases/$(database)/documents/activities/$(activityId)).data
        ) == organizationIdFromData(data);
    }

    function isValidActivityParticipantData(data) {
      return data.keys().hasAll([
          'id',
          'activityId',
          'userId',
          'organizationId',
          'commandId',
          'status'
        ]) &&
        data.id is string &&
        data.activityId is string &&
        data.userId is string &&
        hasValidOrganizationReference(data) &&
        isValidParticipationStatus(data.status) &&
        activityOrganizationMatches(data.activityId, data);
    }

    function isOwnActivityParticipationWrite(participantId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == participantId &&
        participantId == request.resource.data.activityId + '_' + request.auth.uid &&
        isValidActivityParticipantData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data));
    }

    function isValidCertificateType(type) {
      return type == 'firstAid' ||
        type == 'seaRescue' ||
        type == 'radio' ||
        type == 'navigation' ||
        type == 'boatOperator' ||
        type == 'safety' ||
        type == 'other';
    }

    function isValidCertificateStatus(status) {
      return status == 'valid' ||
        status == 'expiringSoon' ||
        status == 'expired' ||
        status == 'missing';
    }

    function isValidCertificateData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'userName',
          'title',
          'type',
          'issuer',
          'issuedAt',
          'expiresAt',
          'status',
          'note',
          'createdBy'
        ]) &&
        data.id is string &&
        data.userId is string &&
        data.userId.size() > 0 &&
        data.userName is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.issuer is string &&
        data.issuedAt is string &&
        data.expiresAt is string &&
        data.note is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidCertificateType(data.type) &&
        isValidCertificateStatus(data.status);
    }

    function canReadCertificate(data) {
      return signedIn() &&
        (
          isActiveAdmin(organizationIdFromData(data)) ||
          (
            data.userId == request.auth.uid &&
            isActiveMember(organizationIdFromData(data))
          )
        );
    }

    function isCertificateCreate(certificateId) {
      return signedIn() &&
        request.resource.data.id == certificateId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidCertificateData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(request.resource.data)) &&
        isActiveMemberOf(
          request.resource.data.userId,
          organizationIdFromData(request.resource.data)
        );
    }

    function isCertificateUpdate(certificateId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == certificateId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidCertificateData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(resource.data)) &&
        isActiveMemberOf(
          resource.data.userId,
          organizationIdFromData(resource.data)
        );
    }

    function isValidNotificationType(type) {
      return type == 'system' ||
        type == 'equipment' ||
        type == 'availability' ||
        type == 'minimumCrew' ||
        type == 'activity' ||
        type == 'callout' ||
        type == 'certificate';
    }

    function isValidNotificationPriority(priority) {
      return priority == 'low' ||
        priority == 'normal' ||
        priority == 'high' ||
        priority == 'critical';
    }

    function isValidNotificationData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'title',
          'message',
          'type',
          'priority',
          'createdBy'
        ]) &&
        data.id is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.message is string &&
        data.message.size() > 0 &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidNotificationType(data.type) &&
        isValidNotificationPriority(data.priority);
    }

    function isNotificationCreate(notificationId) {
      return signedIn() &&
        request.resource.data.id == notificationId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidNotificationData(request.resource.data) &&
        (
          isOwnAvailabilityNotificationCreate() ||
          isOwnMinimumCrewNotificationCreate() ||
          isActiveAdmin(organizationIdFromData(request.resource.data))
        );
    }

    function isOwnAvailabilityNotificationCreate() {
      let organizationId =
        organizationIdFromData(request.resource.data);
      let availabilityId = request.auth.uid + '_' + organizationId;
      let availabilityPath =
        /databases/$(database)/documents/availability/$(availabilityId);
      return request.resource.data.type == 'availability' &&
        request.resource.data.priority == 'normal' &&
        request.resource.data.title == 'Valvesoleku muudatus' &&
        request.resource.data.keys().hasAll(['relatedType', 'relatedId']) &&
        request.resource.data.relatedType == 'availability' &&
        request.resource.data.relatedId == availabilityId &&
        isActiveMember(organizationId) &&
        existsAfter(availabilityPath) &&
        getAfter(availabilityPath).data.userId == request.auth.uid &&
        organizationIdFromData(getAfter(availabilityPath).data) ==
          organizationId &&
        getAfter(availabilityPath).data.updatedAt == request.time &&
        (
          (
            !exists(availabilityPath) &&
            getAfter(availabilityPath).data.status != 'offDuty'
          ) ||
          (
            exists(availabilityPath) &&
            get(availabilityPath).data.status !=
              getAfter(availabilityPath).data.status
          )
        );
    }

    function isOwnMinimumCrewNotificationCreate() {
      let organizationId =
        organizationIdFromData(request.resource.data);
      let summaryPath =
        /databases/$(database)/documents/organizationReadinessSummaries/$(organizationId);
      return request.resource.data.type == 'minimumCrew' &&
        request.resource.data.keys().hasAll(['relatedType', 'relatedId']) &&
        request.resource.data.relatedType == 'organizationReadiness' &&
        request.resource.data.relatedId == organizationId &&
        isActiveMember(organizationId) &&
        exists(summaryPath) &&
        existsAfter(summaryPath) &&
        getAfter(summaryPath).data.lastUpdatedBy == request.auth.uid &&
        getAfter(summaryPath).data.updatedAt == request.time &&
        (
          (
            get(summaryPath).data.minimumCrewMet == true &&
            getAfter(summaryPath).data.minimumCrewMet == false &&
            request.resource.data.title == 'Meeskond alla miinimumi' &&
            request.resource.data.priority == 'high'
          ) ||
          (
            get(summaryPath).data.minimumCrewMet == false &&
            getAfter(summaryPath).data.minimumCrewMet == true &&
            request.resource.data.title == 'Meeskond taastatud' &&
            request.resource.data.priority == 'normal'
          )
        );
    }

    function notificationExists(notificationId) {
      return exists(/databases/$(database)/documents/notifications/$(notificationId));
    }

    function notificationOrganizationMatches(notificationId, data) {
      return notificationExists(notificationId) &&
        organizationIdFromData(
          get(/databases/$(database)/documents/notifications/$(notificationId)).data
        ) == organizationIdFromData(data);
    }

    function isValidNotificationReadData(data) {
      return data.keys().hasAll([
          'id',
          'notificationId',
          'userId',
          'organizationId',
          'commandId'
        ]) &&
        data.id is string &&
        data.notificationId is string &&
        data.userId is string &&
        hasValidOrganizationReference(data) &&
        notificationOrganizationMatches(data.notificationId, data);
    }

    function isOwnNotificationReadWrite(readId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == readId &&
        readId == request.resource.data.notificationId + '_' + request.auth.uid &&
        isValidNotificationReadData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data));
    }

    function isValidCalloutStatus(status) {
      return status == 'active' ||
        status == 'closed' ||
        status == 'cancelled';
    }

    function isValidCalloutPriority(priority) {
      return priority == 'low' ||
        priority == 'normal' ||
        priority == 'high' ||
        priority == 'critical';
    }

    function isValidCalloutData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'title',
          'description',
          'location',
          'status',
          'priority',
          'createdBy',
          'createdByName'
        ]) &&
        data.id is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        data.location is string &&
        data.createdBy is string &&
        data.createdByName is string &&
        hasValidOrganizationReference(data) &&
        isValidCalloutStatus(data.status) &&
        isValidCalloutPriority(data.priority);
    }

    function isCalloutCreate(calloutId) {
      return signedIn() &&
        request.resource.data.id == calloutId &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'active' &&
        isValidCalloutData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(request.resource.data));
    }

    function isCalloutUpdate(calloutId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == calloutId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidCalloutData(request.resource.data) &&
        isActiveAdmin(organizationIdFromData(resource.data));
    }

    function isValidCalloutResponseValue(response) {
      return response == 'responding' ||
        response == 'delayed' ||
        response == 'unavailable' ||
        response == 'noResponse';
    }

    function hasValidCalloutResponseMinutes(data) {
      return (
          data.response != 'delayed' ||
          (
            data.keys().hasAny(['responseMinutes']) &&
            data.responseMinutes is int &&
            data.responseMinutes > 0
          )
        ) &&
        (
          !data.keys().hasAny(['responseMinutes']) ||
          data.responseMinutes == null ||
          data.responseMinutes is int
        );
    }

    function calloutExists(calloutId) {
      return exists(/databases/$(database)/documents/callouts/$(calloutId));
    }

    function calloutData(calloutId) {
      return get(/databases/$(database)/documents/callouts/$(calloutId)).data;
    }

    function calloutOrganizationMatches(calloutId, data) {
      return calloutExists(calloutId) &&
        organizationIdFromData(calloutData(calloutId)) ==
          organizationIdFromData(data);
    }

    function calloutIsActive(calloutId) {
      return calloutExists(calloutId) &&
        calloutData(calloutId).status == 'active';
    }

    function isValidCalloutResponseData(data) {
      return data.keys().hasAll([
          'id',
          'calloutId',
          'userId',
          'userName',
          'organizationId',
          'commandId',
          'response',
          'note'
        ]) &&
        data.id is string &&
        data.calloutId is string &&
        data.userId is string &&
        data.userName is string &&
        data.note is string &&
        hasValidOrganizationReference(data) &&
        isValidCalloutResponseValue(data.response) &&
        data.response != 'noResponse' &&
        hasValidCalloutResponseMinutes(data) &&
        calloutOrganizationMatches(data.calloutId, data);
    }

    function isOwnCalloutResponseWrite(responseId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == responseId &&
        responseId == request.resource.data.calloutId + '_' + request.auth.uid &&
        isValidCalloutResponseData(request.resource.data) &&
        calloutIsActive(request.resource.data.calloutId) &&
        isActiveMember(organizationIdFromData(request.resource.data));
    }

    function isPlatformOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.systemRole ==
          'platformOwner';
    }

    function isSafeUserCreate(userId) {
      return isSelf(userId) &&
        (
          !request.resource.data.keys().hasAny(['systemRole']) ||
          request.resource.data.systemRole == 'user'
        );
    }

    function isSafeUserUpdate(userId) {
      return isSelf(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['systemRole']);
    }

    function isValidReadinessStatus(status) {
      return status == 'ready' ||
        status == 'limited' ||
        status == 'notReady' ||
        status == 'unknown';
    }

    function isValidReadinessEquipmentStatus(status) {
      return status == 'ok' ||
        status == 'issues' ||
        status == 'critical' ||
        status == 'unknown';
    }

    function isValidReadinessSummaryData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'organizationName',
          'region',
          'contactName',
          'contactPhone',
          'readinessStatus',
          'onDutyCount',
          'delayedCount',
          'minimumCrewRequired',
          'minimumCrewMet',
          'primaryVesselStatus',
          'equipmentStatus',
          'criticalIssues',
          'lastUpdatedBy'
        ]) &&
        data.id is string &&
        data.organizationName is string &&
        data.region is string &&
        data.contactName is string &&
        data.contactPhone is string &&
        data.onDutyCount is int &&
        data.onDutyCount >= 0 &&
        data.delayedCount is int &&
        data.delayedCount >= 0 &&
        data.minimumCrewRequired is int &&
        data.minimumCrewRequired >= 0 &&
        data.minimumCrewMet is bool &&
        data.criticalIssues is string &&
        data.lastUpdatedBy is string &&
        hasValidOrganizationReference(data) &&
        isValidReadinessStatus(data.readinessStatus) &&
        isValidReadinessEquipmentStatus(data.primaryVesselStatus) &&
        isValidReadinessEquipmentStatus(data.equipmentStatus);
    }

    function isReadinessSummaryWrite(summaryId) {
      return signedIn() &&
        request.resource.data.id == summaryId &&
        request.resource.data.organizationId == summaryId &&
        request.resource.data.commandId == summaryId &&
        request.resource.data.lastUpdatedBy == request.auth.uid &&
        isValidReadinessSummaryData(request.resource.data) &&
        isActiveAdmin(summaryId);
    }

    function isOwnAvailabilityReadinessSummaryUpdate(summaryId) {
      let availabilityId = request.auth.uid + '_' + summaryId;
      let availabilityPath =
        /databases/$(database)/documents/availability/$(availabilityId);
      return signedIn() &&
        isActiveMember(summaryId) &&
        request.resource.data.id == summaryId &&
        request.resource.data.organizationId == summaryId &&
        request.resource.data.commandId == summaryId &&
        request.resource.data.lastUpdatedBy == request.auth.uid &&
        request.resource.data.lastUpdatedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.minimumCrewRequired > 0 &&
        request.resource.data.minimumCrewMet ==
          (
            request.resource.data.onDutyCount >=
              request.resource.data.minimumCrewRequired
          ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'onDutyCount',
          'minimumCrewMet',
          'lastUpdatedBy',
          'lastUpdatedAt',
          'updatedAt'
        ]) &&
        isValidReadinessSummaryData(request.resource.data) &&
        existsAfter(availabilityPath) &&
        getAfter(availabilityPath).data.userId == request.auth.uid &&
        organizationIdFromData(getAfter(availabilityPath).data) == summaryId &&
        getAfter(availabilityPath).data.updatedAt == request.time &&
        (
          (
            (
              !exists(availabilityPath) ||
              get(availabilityPath).data.status != 'onDuty'
            ) &&
            getAfter(availabilityPath).data.status == 'onDuty' &&
            request.resource.data.onDutyCount ==
              resource.data.onDutyCount + 1
          ) ||
          (
            exists(availabilityPath) &&
            get(availabilityPath).data.status == 'onDuty' &&
            getAfter(availabilityPath).data.status != 'onDuty' &&
            (
              (
                resource.data.onDutyCount > 0 &&
                request.resource.data.onDutyCount ==
                  resource.data.onDutyCount - 1
              ) ||
              (
                resource.data.onDutyCount == 0 &&
                request.resource.data.onDutyCount == 0
              )
            )
          )
        );
    }

    match /users/{userId} {
      // TODO: Restrict user reads to self + same-organization members before production.
      allow read: if signedIn();
      allow create: if isSafeUserCreate(userId);
      allow update: if isSafeUserUpdate(userId);
    }

    match /commands/{commandId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid;

      // TODO: Restrict command updates to command admins with field validation.
      allow update: if signedIn() && isActiveAdmin(commandId);
    }

    match /memberships/{membershipId} {
      // TODO: Restrict membership reads to same-organization members before production.
      allow read: if signedIn();

      allow create: if isOwnAdminMembershipForCreatedCommand() ||
        isOwnMemberMembership();

      allow update: if signedIn() &&
        (
          isAdminMembershipRoleUpdate() ||
          (resource.data.userId == request.auth.uid && keepsMembershipIdentityAndRole())
        );
    }

    match /availability/{availabilityId} {
      // TODO: Restrict availability reads to same-organization members before production.
      allow read: if signedIn();
      allow create, update: if isOwnAvailabilityWrite(availabilityId);
    }

    match /availabilityReminderSettings/{settingId} {
      // TODO: Restrict reminder settings reads to self before production.
      allow read: if signedIn();
      allow create, update: if isOwnReminderSettingsWrite(settingId);
    }

    match /equipment/{equipmentId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create: if isEquipmentCreate(equipmentId);
      allow update: if isEquipmentUpdate(equipmentId);
    }

    match /operationLogs/{logId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create: if isOperationLogCreate(logId);
      allow update: if isOperationLogStatusUpdate(logId);
    }

    match /activities/{activityId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create: if isActivityCreate(activityId);
      allow update: if isActivityUpdate(activityId);
    }

    match /activityParticipants/{participantId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create, update: if isOwnActivityParticipationWrite(participantId);
    }

    match /certificates/{certificateId} {
      allow read: if canReadCertificate(resource.data);
      allow create: if isCertificateCreate(certificateId);
      allow update: if isCertificateUpdate(certificateId);
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create: if isNotificationCreate(notificationId);
    }

    match /notificationReads/{readId} {
      allow read: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create, update: if isOwnNotificationReadWrite(readId);
    }

    match /callouts/{calloutId} {
      allow read: if signedIn() &&
        isActiveMember(organizationIdFromData(resource.data));
      allow create: if isCalloutCreate(calloutId);
      allow update: if isCalloutUpdate(calloutId);
    }

    match /calloutResponses/{responseId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isActiveAdmin(organizationIdFromData(resource.data))
        );
      allow create, update: if isOwnCalloutResponseWrite(responseId);
    }

    match /organizationReadinessSummaries/{summaryId} {
      allow read: if isPlatformOwner() ||
        (
          signedIn() &&
          (
            isActiveMember(summaryId) ||
            isActiveMember(organizationIdFromData(resource.data))
          )
        );
      allow create: if isReadinessSummaryWrite(summaryId);
      allow update: if isReadinessSummaryWrite(summaryId) ||
        isOwnAvailabilityReadinessSummaryUpdate(summaryId);
    }
  }
}
