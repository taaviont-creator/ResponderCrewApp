rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasCommandId(data) {
      return data.keys().hasAny(['commandId']) &&
        data.commandId is string &&
        data.commandId.size() > 0;
    }

    function hasOrganizationId(data) {
      return data.keys().hasAny(['organizationId']) &&
        data.organizationId is string &&
        data.organizationId.size() > 0;
    }

    function organizationIdFromData(data) {
      return hasOrganizationId(data) ? data.organizationId : data.commandId;
    }

    function hasValidOrganizationReference(data) {
      return (hasOrganizationId(data) || hasCommandId(data)) &&
        (!hasOrganizationId(data) ||
          !hasCommandId(data) ||
          data.organizationId == data.commandId);
    }

    function isActiveMembershipData(data) {
      return (
          (data.keys().hasAny(['status']) && data.status == 'active') ||
          (data.keys().hasAny(['isActive']) && data.isActive == true)
        ) &&
        (!data.keys().hasAny(['status']) || data.status == 'active') &&
        (!data.keys().hasAny(['isActive']) || data.isActive == true);
    }

    function isValidMembershipRole(role) {
      return role == 'member' ||
        role == 'orgAdmin';
    }

    function isLegacyMembershipRole(role) {
      return role == 'boardMember' ||
        role == 'admin';
    }

    function isValidSeaRescueLevel(data) {
      return !data.keys().hasAny(['seaRescueLevel']) ||
        data.seaRescueLevel == 'none' ||
        data.seaRescueLevel == 'level1' ||
        data.seaRescueLevel == 'level2';
    }

    function commandExistsAfter(commandId) {
      return existsAfter(/databases/$(database)/documents/commands/$(commandId)) &&
        getAfter(/databases/$(database)/documents/commands/$(commandId)).data.createdBy is string;
    }

    function commandExists(commandId) {
      return exists(/databases/$(database)/documents/commands/$(commandId)) &&
        get(/databases/$(database)/documents/commands/$(commandId)).data.createdBy is string;
    }

    function isCommandCreator(commandId) {
      return commandExistsAfter(commandId) &&
        getAfter(/databases/$(database)/documents/commands/$(commandId)).data.createdBy ==
          request.auth.uid;
    }

    function activeMembershipId(commandId) {
      return request.auth.uid + '_' + commandId;
    }

    function membershipIdForUser(userId, commandId) {
      return userId + '_' + commandId;
    }

    function isActiveMember(commandId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))) &&
        isActiveMembershipData(
          get(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))).data
        );
    }

    function isActiveMemberOf(userId, commandId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/memberships/$(membershipIdForUser(userId, commandId))) &&
        isActiveMembershipData(
          get(/databases/$(database)/documents/memberships/$(membershipIdForUser(userId, commandId))).data
        );
    }

    function isActiveOrgAdmin(commandId) {
      return isActiveMember(commandId) &&
        (
          get(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))).data.role ==
            'orgAdmin' ||
          get(/databases/$(database)/documents/memberships/$(activeMembershipId(commandId))).data.role ==
            'admin'
        );
    }

    function commandAllowsMemberActivityCreate(commandId) {
      let commandPath =
        /databases/$(database)/documents/commands/$(commandId);
      return exists(commandPath) &&
        get(commandPath).data.keys().hasAny([
          'allowMembersToCreateActivities'
        ]) &&
        get(commandPath).data.allowMembersToCreateActivities == true;
    }

    function commandAllowsMemberOperationLogStart(commandId) {
      let commandPath =
        /databases/$(database)/documents/commands/$(commandId);
      return exists(commandPath) &&
        get(commandPath).data.keys().hasAny([
          'allowMembersToStartOperationLog'
        ]) &&
        get(commandPath).data.allowMembersToStartOperationLog == true;
    }

    function canManageOperationLog(commandId) {
      return isPlatformAdmin() ||
        isActiveOrgAdmin(commandId) ||
        (
          isActiveMember(commandId) &&
          commandAllowsMemberOperationLogStart(commandId)
        );
    }

    function hasValidCommandMemberPermissions(data) {
      return (
          !data.keys().hasAny(['allowMembersToCreateActivities']) ||
          data.allowMembersToCreateActivities is bool
        ) &&
        (
          !data.keys().hasAny(['allowMembersToViewStatistics']) ||
          data.allowMembersToViewStatistics is bool
        ) &&
        (
          !data.keys().hasAny(['allowMembersToStartOperationLog']) ||
          data.allowMembersToStartOperationLog is bool
        );
    }

    function isCommandCreateData(data) {
      return data.keys().hasAny(['status']) &&
        data.status == 'pending' &&
        hasValidCommandMemberPermissions(data);
    }

    function commandIsPendingAfter(commandId) {
      return commandExistsAfter(commandId) &&
        getAfter(/databases/$(database)/documents/commands/$(commandId)).data.status ==
          'pending';
    }

    function commandIsApprovedAfter(commandId) {
      return commandExistsAfter(commandId) &&
        (
          !getAfter(/databases/$(database)/documents/commands/$(commandId)).data.keys().hasAny([
            'status'
          ]) ||
          getAfter(/databases/$(database)/documents/commands/$(commandId)).data.status ==
            'approved'
        );
    }

    function commandIsApproved(commandId) {
      return commandExists(commandId) &&
        (
          !get(/databases/$(database)/documents/commands/$(commandId)).data.keys().hasAny([
            'status'
          ]) ||
          get(/databases/$(database)/documents/commands/$(commandId)).data.status ==
            'approved'
        );
    }

    function isCommandMemberPermissionUpdate(commandId) {
      return signedIn() &&
        (isPlatformAdmin() || isActiveOrgAdmin(commandId)) &&
        request.resource.data.allowMembersToCreateActivities is bool &&
        request.resource.data.allowMembersToViewStatistics is bool &&
        request.resource.data.allowMembersToStartOperationLog is bool &&
        request.resource.data.updatedBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'allowMembersToCreateActivities',
          'allowMembersToViewStatistics',
          'allowMembersToStartOperationLog',
          'updatedBy',
          'updatedAt'
        ]);
    }

    function isCommandApprovalUpdate(commandId) {
      let creatorMembershipPath =
        /databases/$(database)/documents/memberships/$(membershipIdForUser(resource.data.createdBy, commandId));
      return signedIn() &&
        isPlatformAdmin() &&
        resource.data.createdBy is string &&
        resource.data.keys().hasAny(['status']) &&
        resource.data.status == 'pending' &&
        (
          request.resource.data.status == 'approved' ||
          request.resource.data.status == 'rejected'
        ) &&
        request.resource.data.reviewedBy == request.auth.uid &&
        request.resource.data.reviewedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'reviewedBy',
          'reviewedAt',
          'updatedAt'
        ]) &&
        existsAfter(creatorMembershipPath) &&
        (
          (
            request.resource.data.status == 'approved' &&
            getAfter(creatorMembershipPath).data.status == 'active' &&
            getAfter(creatorMembershipPath).data.isActive == true
          ) ||
          (
            request.resource.data.status == 'rejected' &&
            getAfter(creatorMembershipPath).data.status == 'rejected' &&
            getAfter(creatorMembershipPath).data.isActive == false
          )
        );
    }

    function isOwnMembershipCreate() {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        isValidSeaRescueLevel(request.resource.data) &&
        isActiveMembershipData(request.resource.data);
    }

    function isOwnOrgAdminMembershipForCreatedCommand() {
      return isOwnMembershipCreate() &&
        request.resource.data.role == 'orgAdmin' &&
        isCommandCreator(organizationIdFromData(request.resource.data)) &&
        commandIsApprovedAfter(organizationIdFromData(request.resource.data));
    }

    function isOwnPendingOrgAdminMembershipForCreatedCommand() {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        isValidSeaRescueLevel(request.resource.data) &&
        request.resource.data.role == 'orgAdmin' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.isActive == false &&
        isCommandCreator(organizationIdFromData(request.resource.data)) &&
        commandIsPendingAfter(organizationIdFromData(request.resource.data));
    }

    function isOwnMemberMembership() {
      return isOwnMembershipCreate() &&
        request.resource.data.role == 'member' &&
        commandIsApprovedAfter(organizationIdFromData(request.resource.data));
    }

    function keepsMembershipIdentityAndRole() {
      return request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        request.resource.data.role == resource.data.role &&
        (
          request.resource.data.keys().hasAny(['seaRescueLevel']) ==
            resource.data.keys().hasAny(['seaRescueLevel'])
        ) &&
        (
          !resource.data.keys().hasAny(['seaRescueLevel']) ||
          request.resource.data.seaRescueLevel == resource.data.seaRescueLevel
        );
    }

    function isOwnMembershipStatusUpdate() {
      return resource.data.userId == request.auth.uid &&
        keepsMembershipIdentityAndRole() &&
        request.resource.data.status == 'removed' &&
        request.resource.data.isActive == false &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'isActive',
          'updatedAt'
        ]);
    }

    function isPlatformApprovalMembershipUpdate() {
      let organizationId = organizationIdFromData(resource.data);
      let commandPath =
        /databases/$(database)/documents/commands/$(organizationId);
      return signedIn() &&
        isPlatformAdmin() &&
        resource.data.userId is string &&
        resource.data.role == 'orgAdmin' &&
        resource.data.status == 'pending' &&
        request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) == organizationId &&
        request.resource.data.role == resource.data.role &&
        isValidSeaRescueLevel(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'isActive',
          'updatedAt'
        ]) &&
        existsAfter(commandPath) &&
        getAfter(commandPath).data.createdBy == resource.data.userId &&
        (
          (
            getAfter(commandPath).data.status == 'approved' &&
            request.resource.data.status == 'active' &&
            request.resource.data.isActive == true
          ) ||
          (
            getAfter(commandPath).data.status == 'rejected' &&
            request.resource.data.status == 'rejected' &&
            request.resource.data.isActive == false
          )
        );
    }

    function isValidOrganizationInviteData(data) {
      return data.keys().hasOnly([
          'organizationId',
          'commandId',
          'email',
          'role',
          'status',
          'invitedBy',
          'createdAt',
          'expiresAt',
          'acceptedBy',
          'acceptedAt'
        ]) &&
        data.keys().hasAll([
          'organizationId',
          'commandId',
          'email',
          'role',
          'status',
          'invitedBy',
          'createdAt',
          'expiresAt',
          'acceptedBy',
          'acceptedAt'
        ]) &&
        data.email is string &&
        data.email.size() > 0 &&
        data.email.matches('^[^@ ]+@[^@ ]+[.][^@ ]+$') &&
        data.role == 'member' &&
        data.status == 'pending' &&
        data.invitedBy is string &&
        data.createdAt == request.time &&
        data.expiresAt is timestamp &&
        data.expiresAt > request.time &&
        data.acceptedBy == null &&
        data.acceptedAt == null &&
        hasValidOrganizationReference(data);
    }

    function canCreateOrganizationInvite(data) {
      let organizationId = organizationIdFromData(data);
      return signedIn() &&
        data.invitedBy == request.auth.uid &&
        commandIsApproved(organizationId) &&
        (
          isPlatformAdmin() ||
          isActiveOrgAdmin(organizationId)
        ) &&
        isValidOrganizationInviteData(data);
    }

    function isOwnOrganizationInvite(data) {
      return signedIn() &&
        request.auth.token.email is string &&
        data.email is string &&
        data.email == request.auth.token.email.lower();
    }

    function isAcceptableOrganizationInvite(data) {
      return isOwnOrganizationInvite(data) &&
        data.status == 'pending' &&
        data.expiresAt is timestamp &&
        data.expiresAt > request.time &&
        data.role == 'member' &&
        hasValidOrganizationReference(data) &&
        commandIsApproved(organizationIdFromData(data));
    }

    function isAcceptedInviteMembershipData(inviteId, data) {
      let invitePath =
        /databases/$(database)/documents/organizationInvites/$(inviteId);
      let organizationId = organizationIdFromData(data);
      return signedIn() &&
        data.acceptedInviteId == inviteId &&
        existsAfter(invitePath) &&
        getAfter(invitePath).data.status == 'accepted' &&
        getAfter(invitePath).data.acceptedBy == request.auth.uid &&
        getAfter(invitePath).data.acceptedAt == request.time &&
        organizationIdFromData(getAfter(invitePath).data) == organizationId &&
        isOwnOrganizationInvite(getAfter(invitePath).data) &&
        commandIsApproved(organizationId);
    }

    function isInviteMembershipCreate(membershipId) {
      let organizationId = organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.keys().hasOnly([
          'userId',
          'organizationId',
          'commandId',
          'role',
          'seaRescueLevel',
          'status',
          'isActive',
          'joinedAt',
          'updatedAt',
          'acceptedInviteId'
        ]) &&
        request.resource.data.keys().hasAll([
          'userId',
          'organizationId',
          'commandId',
          'role',
          'seaRescueLevel',
          'status',
          'isActive',
          'joinedAt',
          'updatedAt',
          'acceptedInviteId'
        ]) &&
        membershipId == membershipIdForUser(request.auth.uid, organizationId) &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        request.resource.data.role == 'member' &&
        request.resource.data.seaRescueLevel == 'none' &&
        request.resource.data.status == 'active' &&
        request.resource.data.isActive == true &&
        request.resource.data.joinedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.acceptedInviteId is string &&
        isAcceptedInviteMembershipData(
          request.resource.data.acceptedInviteId,
          request.resource.data
        );
    }

    function isInviteMembershipUpdate(membershipId) {
      let organizationId = organizationIdFromData(request.resource.data);
      return signedIn() &&
        !isActiveMembershipData(resource.data) &&
        request.resource.data.userId == request.auth.uid &&
        organizationIdFromData(request.resource.data) == organizationIdFromData(resource.data) &&
        membershipId == membershipIdForUser(request.auth.uid, organizationId) &&
        hasValidOrganizationReference(request.resource.data) &&
        request.resource.data.role == 'member' &&
        request.resource.data.seaRescueLevel == 'none' &&
        request.resource.data.status == 'active' &&
        request.resource.data.isActive == true &&
        request.resource.data.joinedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.acceptedInviteId is string &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'role',
          'seaRescueLevel',
          'status',
          'isActive',
          'joinedAt',
          'updatedAt',
          'acceptedInviteId'
        ]) &&
        isAcceptedInviteMembershipData(
          request.resource.data.acceptedInviteId,
          request.resource.data
        );
    }

    function isOrganizationInviteAccept(inviteId) {
      let organizationId = organizationIdFromData(resource.data);
      let membershipPath =
        /databases/$(database)/documents/memberships/$(membershipIdForUser(request.auth.uid, organizationId));
      return isAcceptableOrganizationInvite(resource.data) &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.acceptedBy == request.auth.uid &&
        request.resource.data.acceptedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'acceptedBy',
          'acceptedAt'
        ]) &&
        existsAfter(membershipPath) &&
        isAcceptedInviteMembershipData(
          inviteId,
          getAfter(membershipPath).data
        );
    }

    function canReadOrganizationInvite(data) {
      let organizationId = organizationIdFromData(data);
      return (
          isOwnOrganizationInvite(data) &&
          data.status == 'pending' &&
          hasValidOrganizationReference(data) &&
          commandIsApproved(organizationId)
        ) ||
        (
          signedIn() &&
          commandIsApproved(organizationId) &&
          (
            isPlatformAdmin() ||
            isActiveOrgAdmin(organizationId)
          )
        );
    }

    function isOrgAdminMembershipUpdate() {
      return request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        (
          isValidMembershipRole(request.resource.data.role) ||
          (
            request.resource.data.role == resource.data.role &&
            isLegacyMembershipRole(resource.data.role)
          )
        ) &&
        isValidSeaRescueLevel(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'role',
          'seaRescueLevel',
          'updatedAt'
        ]) &&
        isActiveOrgAdmin(organizationIdFromData(resource.data));
    }

    function isValidAvailabilityStatus(status) {
      return status == 'offDuty' ||
        status == 'onDuty' ||
        status == 'delayed';
    }

    function hasValidDelayedResponse(data) {
      return data.status != 'delayed' ||
        (
          data.keys().hasAny(['responseMinutes']) &&
          data.responseMinutes is int &&
          data.responseMinutes > 0
        );
    }

    function hasValidAvailabilityResponse(data) {
      return !data.keys().hasAny(['responseMinutes']) ||
        data.responseMinutes == null ||
        data.responseMinutes is int;
    }

    function isOwnAvailabilityWrite(availabilityId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        hasValidOrganizationReference(request.resource.data) &&
        availabilityId == request.auth.uid + '_' + organizationIdFromData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data)) &&
        isValidAvailabilityStatus(request.resource.data.status) &&
        hasValidAvailabilityResponse(request.resource.data) &&
        hasValidDelayedResponse(request.resource.data);
    }

    function isValidPlannedUnavailabilityStatus(status) {
      return status == 'active' ||
        status == 'cancelled';
    }

    function isValidPlannedUnavailabilityBaseData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'startAt',
          'endAt',
          'note',
          'status',
          'createdAt',
          'createdBy',
          'updatedAt'
        ]) &&
        data.id is string &&
        data.userId is string &&
        data.startAt is timestamp &&
        data.endAt is timestamp &&
        data.startAt < data.endAt &&
        data.note is string &&
        data.createdBy is string &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        hasValidOrganizationReference(data) &&
        isValidPlannedUnavailabilityStatus(data.status);
    }

    function canReadPlannedUnavailability(data) {
      let organizationId = organizationIdFromData(data);
      return signedIn() &&
        hasValidOrganizationReference(data) &&
        (
          (
            data.userId == request.auth.uid &&
            isActiveMember(organizationId)
          ) ||
          isActiveOrgAdmin(organizationId)
        );
    }

    function isOwnPlannedUnavailabilityCreate(periodId) {
      let organizationId = organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'startAt',
          'endAt',
          'note',
          'status',
          'createdAt',
          'createdBy',
          'updatedAt'
        ]) &&
        request.resource.data.id == periodId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'active' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        isValidPlannedUnavailabilityBaseData(request.resource.data) &&
        isActiveMember(organizationId);
    }

    function keepsPlannedUnavailabilityIdentity() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        request.resource.data.startAt == resource.data.startAt &&
        request.resource.data.endAt == resource.data.endAt &&
        request.resource.data.note == resource.data.note &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.createdBy == resource.data.createdBy;
    }

    function isOwnPlannedUnavailabilityCancel(periodId) {
      let organizationId = organizationIdFromData(resource.data);
      return signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.id == periodId &&
        keepsPlannedUnavailabilityIdentity() &&
        resource.data.status == 'active' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.cancelledAt == request.time &&
        request.resource.data.cancelledBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelledBy',
          'updatedAt'
        ]) &&
        isValidPlannedUnavailabilityBaseData(request.resource.data) &&
        isActiveMember(organizationId);
    }

    function isValidPlannedUnavailabilityRuleTime(data) {
      return data.startTime is string &&
        data.startTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
        data.endTime is string &&
        data.endTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') &&
        data.startMinute is int &&
        data.endMinute is int &&
        data.startMinute >= 0 &&
        data.startMinute <= 1439 &&
        data.endMinute >= 0 &&
        data.endMinute <= 1439 &&
        data.startMinute < data.endMinute;
    }

    function isValidPlannedUnavailabilityRuleDays(days) {
      return days is list &&
        days.size() > 0 &&
        days.size() <= 7 &&
        days.hasOnly([1, 2, 3, 4, 5, 6, 7]);
    }

    function isValidPlannedUnavailabilityRuleBaseData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'daysOfWeek',
          'startTime',
          'endTime',
          'startMinute',
          'endMinute',
          'note',
          'status',
          'createdAt',
          'createdBy',
          'updatedAt'
        ]) &&
        data.id is string &&
        data.userId is string &&
        data.note is string &&
        data.createdBy is string &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        hasValidOrganizationReference(data) &&
        isValidPlannedUnavailabilityRuleDays(data.daysOfWeek) &&
        isValidPlannedUnavailabilityRuleTime(data) &&
        isValidPlannedUnavailabilityStatus(data.status);
    }

    function canReadPlannedUnavailabilityRule(data) {
      let organizationId = organizationIdFromData(data);
      return signedIn() &&
        hasValidOrganizationReference(data) &&
        (
          (
            data.userId == request.auth.uid &&
            isActiveMember(organizationId)
          ) ||
          isActiveOrgAdmin(organizationId)
        );
    }

    function isOwnPlannedUnavailabilityRuleCreate(ruleId) {
      let organizationId = organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'daysOfWeek',
          'startTime',
          'endTime',
          'startMinute',
          'endMinute',
          'note',
          'status',
          'createdAt',
          'createdBy',
          'updatedAt'
        ]) &&
        request.resource.data.id == ruleId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'active' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        isValidPlannedUnavailabilityRuleBaseData(request.resource.data) &&
        isActiveMember(organizationId);
    }

    function keepsPlannedUnavailabilityRuleIdentity() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        request.resource.data.daysOfWeek == resource.data.daysOfWeek &&
        request.resource.data.startTime == resource.data.startTime &&
        request.resource.data.endTime == resource.data.endTime &&
        request.resource.data.startMinute == resource.data.startMinute &&
        request.resource.data.endMinute == resource.data.endMinute &&
        request.resource.data.note == resource.data.note &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.createdBy == resource.data.createdBy;
    }

    function isOwnPlannedUnavailabilityRuleCancel(ruleId) {
      let organizationId = organizationIdFromData(resource.data);
      return signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.id == ruleId &&
        keepsPlannedUnavailabilityRuleIdentity() &&
        resource.data.status == 'active' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.cancelledAt == request.time &&
        request.resource.data.cancelledBy == request.auth.uid &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelledBy',
          'updatedAt'
        ]) &&
        isValidPlannedUnavailabilityRuleBaseData(request.resource.data) &&
        isActiveMember(organizationId);
    }

    function isValidReminderInterval(intervalHours) {
      return intervalHours == 12 ||
        intervalHours == 24 ||
        intervalHours == 48 ||
        intervalHours == 168;
    }

    function isValidReminderTime(reminderTime) {
      return reminderTime is string &&
        reminderTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isValidReminderSettingsData(data) {
      return data.keys().hasAll(['enabled', 'intervalHours', 'reminderTime']) &&
        data.enabled is bool &&
        isValidReminderInterval(data.intervalHours) &&
        isValidReminderTime(data.reminderTime);
    }

    function isOwnReminderSettingsWrite(settingId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == settingId &&
        hasValidOrganizationReference(request.resource.data) &&
        settingId == request.auth.uid + '_' + organizationIdFromData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data)) &&
        isValidReminderSettingsData(request.resource.data);
    }

    function isValidEquipmentCategory(category) {
      return category == 'vessel' ||
        category == 'engine' ||
        category == 'rescue' ||
        category == 'medical' ||
        category == 'radio' ||
        category == 'safety' ||
        category == 'other';
    }

    function isValidEquipmentStatus(status) {
      return status == 'ok' ||
        status == 'needsMaintenance' ||
        status == 'broken' ||
        status == 'outOfService';
    }

    function equipmentScope(data) {
      return data.keys().hasAny(['scope'])
        ? data.scope
        : 'organization';
    }

    function isValidEquipmentScope(scope) {
      return scope == 'organization' ||
        scope == 'personal';
    }

    function hasValidEquipmentOwnership(data) {
      let scope = equipmentScope(data);
      return isValidEquipmentScope(scope) &&
        (
          (
            scope == 'organization' &&
            (
              !data.keys().hasAny(['ownerUserId']) ||
              data.ownerUserId == null ||
              data.ownerUserId == ''
            )
          ) ||
          (
            scope == 'personal' &&
            data.keys().hasAny(['ownerUserId']) &&
            data.ownerUserId is string &&
            data.ownerUserId.size() > 0 &&
            isActiveMemberOf(
              data.ownerUserId,
              organizationIdFromData(data)
            )
          )
        );
    }

    function isValidEquipmentData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'name',
          'category',
          'status',
          'location',
          'note',
          'createdBy'
        ]) &&
        data.id is string &&
        data.name is string &&
        data.name.size() > 0 &&
        data.location is string &&
        (
          !data.keys().hasAny(['nextMaintenanceDate']) ||
          data.nextMaintenanceDate is string
        ) &&
        data.note is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        hasValidEquipmentOwnership(data) &&
        isValidEquipmentCategory(data.category) &&
        isValidEquipmentStatus(data.status);
    }

    function canReadEquipment(data) {
      let organizationId =
        organizationIdFromData(data);
      return signedIn() &&
        (
          isPlatformAdmin() ||
          (
            equipmentScope(data) == 'organization' &&
            isActiveMember(organizationId)
          ) ||
          (
            equipmentScope(data) == 'personal' &&
            isActiveMember(organizationId) &&
            (
              data.ownerUserId == request.auth.uid ||
              isActiveOrgAdmin(organizationId)
            )
          )
        );
    }

    function isEquipmentCreate(equipmentId) {
      let organizationId =
        organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.id == equipmentId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidEquipmentData(request.resource.data) &&
        (
          isPlatformAdmin() ||
          (
            isActiveMember(organizationId) &&
            (
              (
                equipmentScope(request.resource.data) == 'personal' &&
                request.resource.data.ownerUserId == request.auth.uid
              ) ||
              (
                equipmentScope(request.resource.data) == 'organization' &&
                isActiveOrgAdmin(organizationId)
              )
            )
          )
        );
    }

    function isEquipmentUpdate(equipmentId) {
      let organizationId =
        organizationIdFromData(resource.data);
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == equipmentId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        equipmentScope(request.resource.data) ==
          equipmentScope(resource.data) &&
        (
          equipmentScope(resource.data) != 'personal' ||
          request.resource.data.ownerUserId == resource.data.ownerUserId
        ) &&
        isValidEquipmentData(request.resource.data) &&
        (
          isPlatformAdmin() ||
          (
            isActiveMember(organizationId) &&
            (
              (
                equipmentScope(resource.data) == 'personal' &&
                request.resource.data.ownerUserId ==
                  resource.data.ownerUserId &&
                (
                  resource.data.ownerUserId == request.auth.uid ||
                  isActiveOrgAdmin(organizationId)
                )
              ) ||
              (
                equipmentScope(resource.data) == 'organization' &&
                isActiveOrgAdmin(organizationId)
              )
            )
          )
        );
    }

    function isValidOperationLogType(type) {
      return type == 'departure' ||
        type == 'arrivalOnScene' ||
        type == 'searchStarted' ||
        type == 'searchEnded' ||
        type == 'patientRecovered' ||
        type == 'towingStarted' ||
        type == 'towingEnded' ||
        type == 'returnedToBase' ||
        type == 'note' ||
        type == 'other';
    }

    function isValidOperationLogStatus(status) {
      return status == 'open' ||
        status == 'enRoute' ||
        status == 'onScene' ||
        status == 'inProgress' ||
        status == 'completed' ||
        status == 'returnedToBase' ||
        status == 'created' ||
        status == 'departed' ||
        status == 'arrived';
    }

    function operationLogStatusFromData(data) {
      return data.keys().hasAny(['status']) ? data.status : 'open';
    }

    function isValidCoordinateNumber(value, minValue, maxValue) {
      return (value is int || value is float) &&
        value >= minValue &&
        value <= maxValue;
    }

    function hasValidOperationLogEventLocation(data) {
      return !data.keys().hasAny([
          'latitude',
          'longitude',
          'accuracyMeters'
        ]) ||
        (
          data.keys().hasAll(['latitude', 'longitude']) &&
          isValidCoordinateNumber(data.latitude, -90, 90) &&
          isValidCoordinateNumber(data.longitude, -180, 180) &&
          (
            !data.keys().hasAny(['accuracyMeters']) ||
            data.accuracyMeters == null ||
            (
              (data.accuracyMeters is int ||
                data.accuracyMeters is float) &&
              data.accuracyMeters >= 0
            )
          )
        );
    }

    function isValidOperationLogData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'createdBy',
          'createdByName',
          'type',
          'title',
          'description'
        ]) &&
        data.id is string &&
        data.createdBy is string &&
        data.createdByName is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        (
          !data.keys().hasAny(['status']) ||
          isValidOperationLogStatus(data.status)
        ) &&
        (
          !data.keys().hasAny(['summary']) ||
          data.summary is string
        ) &&
        (
          !data.keys().hasAny(['outcome']) ||
          data.outcome is string
        ) &&
        (
          !data.keys().hasAny(['completedBy']) ||
          data.completedBy is string
        ) &&
        (
          !data.keys().hasAny(['completedAt']) ||
          data.completedAt == null ||
          data.completedAt is timestamp
        ) &&
        (
          !data.keys().hasAny(['calloutId']) ||
          (
            data.calloutId is string &&
            data.calloutId.size() > 0 &&
            existsAfter(
              /databases/$(database)/documents/callouts/$(data.calloutId)
            ) &&
            organizationIdFromData(
              getAfter(
                /databases/$(database)/documents/callouts/$(data.calloutId)
              ).data
            ) == organizationIdFromData(data)
          )
        ) &&
        hasValidOrganizationReference(data) &&
        isValidOperationLogType(data.type);
    }

    function isOperationLogCreate(logId) {
      let organizationId =
        organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.id == logId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidOperationLogData(request.resource.data) &&
        canManageOperationLog(organizationId);
    }

    function isOperationLogStatusUpdate(logId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == logId &&
        request.resource.data.status is string &&
        isValidOperationLogStatus(request.resource.data.status) &&
        (
          !resource.data.keys().hasAny(['status']) ||
          request.resource.data.status != resource.data.status
        ) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]) &&
        canManageOperationLog(organizationIdFromData(resource.data));
    }

    function isOperationLogSummaryUpdate(logId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == logId &&
        resource.data.status == 'completed' &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.summary is string &&
        request.resource.data.outcome is string &&
        request.resource.data.completedBy == request.auth.uid &&
        request.resource.data.completedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        (
          !resource.data.keys().hasAny(['summary']) ||
          request.resource.data.summary != resource.data.summary ||
          !resource.data.keys().hasAny(['outcome']) ||
          request.resource.data.outcome != resource.data.outcome
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'summary',
          'outcome',
          'completedAt',
          'completedBy',
          'updatedAt'
        ]) &&
        isActiveMember(organizationIdFromData(resource.data));
    }

    function isOperationLogEventCreate(logId, eventId) {
      let logPath =
        /databases/$(database)/documents/operationLogs/$(logId);
      return signedIn() &&
        request.resource.data.id == eventId &&
        request.resource.data.operationLogId == logId &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'operationLogId',
          'type',
          'status',
          'title',
          'description',
          'createdBy',
          'createdAt'
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.description is string &&
        (
          request.resource.data.type != 'manualNote' ||
          (
            request.resource.data.keys().hasAny(['text']) &&
            request.resource.data.text is string &&
            request.resource.data.text.size() > 0 &&
            request.resource.data.text == request.resource.data.title
          )
        ) &&
        (
          request.resource.data.type == 'statusChange' ||
          request.resource.data.type == 'manualNote' ||
          request.resource.data.type == 'quickAction' ||
          request.resource.data.type == 'summarySaved'
        ) &&
        request.resource.data.createdAt == request.time &&
        hasValidOrganizationReference(request.resource.data) &&
        hasValidOperationLogEventLocation(request.resource.data) &&
        isValidOperationLogStatus(request.resource.data.status) &&
        existsAfter(logPath) &&
        organizationIdFromData(getAfter(logPath).data) ==
          organizationIdFromData(request.resource.data) &&
        operationLogStatusFromData(getAfter(logPath).data) ==
          request.resource.data.status &&
        (
          (
            request.resource.data.type == 'statusChange' &&
            getAfter(logPath).data.updatedAt == request.time
          ) ||
          (
            (
              request.resource.data.type == 'manualNote' ||
              request.resource.data.type == 'quickAction'
            ) &&
            exists(logPath) &&
            operationLogStatusFromData(getAfter(logPath).data) ==
              operationLogStatusFromData(get(logPath).data)
          ) ||
          (
            request.resource.data.type == 'summarySaved' &&
            exists(logPath) &&
            getAfter(logPath).data.status == 'completed' &&
            getAfter(logPath).data.completedBy == request.auth.uid &&
            getAfter(logPath).data.completedAt == request.time &&
            getAfter(logPath).data.updatedAt == request.time &&
            request.resource.data.title == 'Lõppkokkuvõte salvestatud' &&
            request.resource.data.description ==
              getAfter(logPath).data.outcome
          )
        ) &&
        canManageOperationLog(organizationIdFromData(request.resource.data));
    }

    function isValidActivityType(type) {
      return type == 'training' ||
        type == 'meeting' ||
        type == 'maintenance' ||
        type == 'exercise' ||
        type == 'event' ||
        type == 'other';
    }

    function isValidActivityData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'title',
          'description',
          'type',
          'startTime',
          'endTime',
          'location',
          'createdBy'
        ]) &&
        data.id is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.description is string &&
        data.startTime is string &&
        data.endTime is string &&
        data.location is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidActivityType(data.type);
    }

    function isActivityCreate(activityId) {
      let organizationId =
        organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.id == activityId &&
        request.resource.data.createdBy == request.auth.uid &&
        isValidActivityData(request.resource.data) &&
        (
          isActiveOrgAdmin(organizationId) ||
          (
            isActiveMember(organizationId) &&
            commandAllowsMemberActivityCreate(organizationId)
          )
        );
    }

    function isActivityUpdate(activityId) {
      return signedIn() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.id == activityId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        isValidActivityData(request.resource.data) &&
        isActiveOrgAdmin(organizationIdFromData(resource.data));
    }

    function isValidParticipationStatus(status) {
      return status == 'attending' ||
        status == 'notAttending' ||
        status == 'maybe' ||
        status == 'registered' ||
        status == 'cannotAttend' ||
        status == 'attendedSelfReported' ||
        status == 'notResponded';
    }

    function isValidAttendanceStatus(status) {
      return status == 'notConfirmed' ||
        status == 'confirmed' ||
        status == 'absent';
    }

    function hasValidActivityConfirmationData(data) {
      return (
          !data.keys().hasAny(['attendanceStatus']) ||
          isValidAttendanceStatus(data.attendanceStatus)
        ) &&
        (
          !data.keys().hasAny(['hours']) ||
          data.hours == null ||
          (
            (data.hours is int || data.hours is float) &&
            data.hours >= 0
          )
        ) &&
        (
          !data.keys().hasAny(['confirmedBy']) ||
          data.confirmedBy is string
        ) &&
        (
          !data.keys().hasAny(['confirmedAt']) ||
          data.confirmedAt == null ||
          data.confirmedAt is timestamp
        );
    }

    function activityExists(activityId) {
      return exists(/databases/$(database)/documents/activities/$(activityId));
    }

    function activityOrganizationMatches(activityId, data) {
      return activityExists(activityId) &&
        organizationIdFromData(
          get(/databases/$(database)/documents/activities/$(activityId)).data
        ) == organizationIdFromData(data);
    }

    function isValidActivityParticipantData(data) {
      return data.keys().hasOnly([
          'id',
          'activityId',
          'userId',
          'organizationId',
          'commandId',
          'status',
          'createdAt',
          'updatedAt',
          'attendanceStatus',
          'hours',
          'confirmedBy',
          'confirmedAt'
        ]) &&
        data.keys().hasAll([
          'id',
          'activityId',
          'userId',
          'organizationId',
          'commandId',
          'status'
        ]) &&
        data.id is string &&
        data.activityId is string &&
        data.userId is string &&
        hasValidOrganizationReference(data) &&
        isValidParticipationStatus(data.status) &&
        activityOrganizationMatches(data.activityId, data) &&
        (
          !data.keys().hasAny(['createdAt']) ||
          data.createdAt is timestamp
        ) &&
        (
          !data.keys().hasAny(['updatedAt']) ||
          data.updatedAt is timestamp
        ) &&
        hasValidActivityConfirmationData(data);
    }

    function hasNoActivityConfirmationData(data) {
      return !data.keys().hasAny([
        'attendanceStatus',
        'hours',
        'confirmedBy',
        'confirmedAt'
      ]);
    }

    function keepsActivityParticipantIdentity() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.activityId == resource.data.activityId &&
        request.resource.data.userId == resource.data.userId &&
        hasValidOrganizationReference(request.resource.data) &&
        organizationIdFromData(request.resource.data) ==
          organizationIdFromData(resource.data) &&
        (
          !resource.data.keys().hasAny(['createdAt']) ||
          request.resource.data.createdAt == resource.data.createdAt
        );
    }

    function isOwnActivityParticipationCreate(participantId) {
      return signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.id == participantId &&
        participantId == request.resource.data.activityId + '_' + request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        hasNoActivityConfirmationData(request.resource.data) &&
        isValidActivityParticipantData(request.resource.data) &&
        isActiveMember(organizationIdFromData(request.resource.data));
    }

    function isActivityParticipationConfirmationCreate(participantId) {
      let organizationId = organizationIdFromData(request.resource.data);
      return signedIn() &&
        request.resource.data.id == participantId &&
        participantId == request.resource.data.activityId + '_' + request.resource.data.userId &&
        request.resource.data.status == 'notResponded' &&
        request.resource.data.keys().hasAny(['attendanceStatus']) &&
        request.resource.data.confirmedBy == request.auth.uid &&
        request.resource.data.confirmedAt == request.time &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        isValidActivityParticipantData(request.resource.data) &&
        isActiveOrgAdmin(organizationId) &&
        isActiveMemberOf(request.resource.data.userId, organizationId);
    }

    function isOwnActivityParticipationUpdate(participantId) {
      return signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.id == participantId &&
        participantId == resource.data.activityId + '_' + request.auth.uid &&
        keepsActivityParticipantIdentity() &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]) &&
        isValidActivityParticipantData(request.resource.data) &&
        isActiveMember(organizationIdFromData(resource.data));
    }

    function isActivityParticipationConfirmationUpdate(participantId) {
      let organizationId = organizationIdFromData(resource.data);
      return signedIn() &&
        request.resource.data.id == participantId &&
        keepsActivityParticipantIdentity() &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.keys().hasAny(['attendanceStatus']) &&
        request.resource.data.confirmedBy == request.auth.uid &&
        request.resource.data.confirmedAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceStatus',
          'hours',
          'confirmedBy',
          'confirmedAt',
          'updatedAt'
        ]) &&
        isValidActivityParticipantData(request.resource.data) &&
        isActiveOrgAdmin(organizationId) &&
        isActiveMemberOf(resource.data.userId, organizationId);
    }

    function isValidCertificateType(type) {
      return type == 'firstAid' ||
        type == 'seaRescue' ||
        type == 'radio' ||
        type == 'navigation' ||
        type == 'boatOperator' ||
        type == 'safety' ||
        type == 'other';
    }

    function isValidCertificateStatus(status) {
      return status == 'valid' ||
        status == 'expiringSoon' ||
        status == 'expired' ||
        status == 'missing';
    }

    function isValidCertificateData(data) {
      return data.keys().hasAll([
          'id',
          'organizationId',
          'commandId',
          'userId',
          'userName',
          'title',
          'type',
          'issuer',
          'issuedAt',
          'expiresAt',
          'status',
          'note',
          'createdBy'
        ]) &&
        data.id is string &&
        data.userId is string &&
        data.userId.size() > 0 &&
        data.userName is string &&
        data.title is string &&
        data.title.size() > 0 &&
        data.issuer is string &&
        data.issuedAt is string &&
        data.expiresAt is string &&
        data.note is string &&
        data.createdBy is string &&
        hasValidOrganizationReference(data) &&
        isValidCertificateType(data.type) &&
        isValidCertificateStatus(data.status);
    }

    function canReadCertificate(data) {
      return signedIn() &&
        (
          isActiveOrgAdmin(organizationIdFromData(data)) ||
          (
            data.userId == request.auth.uid &&
            isActiveMember(organizationIdFromData(data))
          )
        );
